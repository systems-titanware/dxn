{

    "serviceMesh": {
        "registryUrl": "https://registry.dxn.io",
        "discoveryInterval": 300,
        "localServices": [
            {
                "name": "my_ai",
                "url": "https://my-ai.example.com",
                "serviceType": "ai",
                "capabilities": ["text_generation", "sentiment_analysis"],
                "auth": {
                    "authType": "oauth",
                    "clientId": "my-server-client-id"
                },
                "healthCheck": "/api/health"
            },
            {
                "name": "my_wallet",
                "url": "https://my-wallet.example.com",
                "serviceType": "wallet",
                "capabilities": ["zksync", "ethereum"],
                "healthCheck": "/api/health"
            }
        ],
        "publicServices": [
            {
                "name": "public_zksync",
                "discoverFrom": "registry",
                "filter": {
                    "serviceType": "zksync",
                    "public": true,
                    "capabilities": ["bridge", "swap"]
                }
            },
            {
                "name": "public_ai",
                "discoverFrom": "registry",
                "filter": {
                    "serviceType": "ai",
                    "public": true,
                    "capabilities": ["llm"]
                }
            }
        ]
    },
    "integrations": {
        "public": [
            {
                "name": "wallet",
                "path": "integrations/parser",
                "version": "1",
                "integrationType": "Local",
                "serviceName": "zksync",
                "owner": "UUID",
                "functions": [
                    {
                        "name": "parse_html",
                        "params": {
                            "parameter1": "hello world"
                        }
                    }
                ],
                "crates": "zksync"
            },
            {
                "name": "parser",
                "path": "integrations/parser",
                "version": "1",
                "integrationType": "Local",
                "serviceName": "parser",
                "owner": "UUID",
                "functions": [
                    {
                        "name": "parse_html",
                        "params": {
                            "parameter1": "hello world"
                        }
                    }
                ],
                "crates": "html2markdown"
            },
            {
                "name": "llm",
                "path": "integrations/parser",
                "owner": "UUID",
                "integrationType": "Local",
                "serviceName": "huggingface",
                "version": "1",
                "functions": [
                    {
                        "name": "parse_html",
                        "params": {
                            "parameter1": "hello world"
                        }
                    }
                ],
                "crates": "huggingface"
            }
        ]
    },
    "functions": {
        "public": [
            {
                "name": "no_params",
                "version": 1,
                "path": "../dxn-functions/target/wasm32-unknown-unknown/release/dxn-functions.wasm",
                "functionName": "no_params"
            },
            {
                "name": "no_params_with_result",
                "version": 1,
                "path": "../dxn-functions/target/wasm32-unknown-unknown/release/dxn-functions.wasm",
                "functionName": "no_params_with_result"
            },
            {
                "name": "serialized_params",
                "version": 1,
                "path": "../dxn-functions/target/wasm32-unknown-unknown/release/dxn-functions.wasm",
                "functionName": "serialized_params"
            },
            {
                "name": "typed_params",
                "version": 1,
                "path": "../dxn-functions/target/wasm32-unknown-unknown/release/dxn-functions.wasm",
                "functionName": "typed_params",
                "parameters": [ "i32", "i32" ]
            }
        ]
    },
    "server": {
        "public": [
            {
                "name": "test",
                "file": "post.md",
                "function": "typed_params",
                "params": [ 30, 32 ],
                "routes": [
                    {
                        "name": "baby-test",
                        "file": "subpage.html",
                        "routes": []
                    }
                ]
            },
            {
                "name": "tester",
                "function": "parse_markdown",
                "params": [ "post.md" ],
                "file": "tester.html",
                "routes": []
            }
        ]
    },
    "data": {
        "public": [
            {
                "name": "profile",
                "version": 1,
                "db": "public",
                "fields": [
                    {
                        "name": "email",
                        "datatype": "text",
                        "value": "{vault.profile.email}"
                    },
                    {
                        "name": "phone",
                        "datatype": "text",
                        "value": "{vault.profile.phone}"
                    }
                ]
            },
            {
                "name": "wallet",
                "version": 1,
                "db": "private",
                "fields": [
                    {
                        "name": "address",
                        "datatype": "text",
                        "value": "{vault.profile.email}"
                    },
                    {
                        "name": "test",
                        "datatype": "text",
                        "value": "{vault.profile.phone}"
                    }
                ]
            }
        ]
    }
}